<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GooglePhotoManager.Views.WizardView">

    <Grid RowDefinitions="*">

        <!-- STEP 0: Home -->
        <ScrollViewer x:Name="Step0">
            <StackPanel Margin="12,8" Spacing="8">
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Backup Foto" FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <TextBlock Text="Trasferisci le foto dai tuoi dispositivi al dispositivo di backup"
                                   TextWrapping="Wrap" Foreground="#757575"
                                   FontSize="13" Margin="0,0,0,6"/>

                        <Button x:Name="BtnStartWizard" Content="AVVIA"
                                HorizontalAlignment="Stretch" Padding="6,3"
                                Background="#5C6BC0" Foreground="White"
                                Click="OnStartWizardClick"/>

                        <Button x:Name="BtnSimulate" Content="SIMULA (DEBUG)"
                                HorizontalAlignment="Stretch" Padding="6,3" IsVisible="False"
                                Background="#E65100" Foreground="White"
                                Click="OnSimulateClick"/>

                        <TextBlock x:Name="LabelStep0Error" Text="" HorizontalAlignment="Center"
                                   Foreground="#EF5350" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- STEP 1: Backup device -->
        <ScrollViewer x:Name="Step1" IsVisible="False">
            <StackPanel Margin="12,8" Spacing="8">
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="1/4 — Dispositivo di backup" FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <TextBlock Text="Quale dispositivo ricevera le foto?"
                                   Foreground="#757575" FontSize="13"/>

                        <ListBox x:Name="BackupDeviceList" MinHeight="34" MaxHeight="160"/>

                        <Grid ColumnDefinitions="*,6,*" HorizontalAlignment="Stretch">
                            <Button Content="Indietro" Grid.Column="0"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnBackToStep0"/>
                            <Button x:Name="BtnStep1Next" Content="Avanti" Grid.Column="2"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Background="#5C6BC0" Foreground="White"
                                    Click="OnStep1Next"/>
                        </Grid>

                        <TextBlock x:Name="LabelStep1Error" Text="" HorizontalAlignment="Center"
                                   Foreground="#EF5350" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- STEP 2: Utente -->
        <ScrollViewer x:Name="Step2" IsVisible="False">
            <StackPanel Margin="12,8" Spacing="8">
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <StackPanel Spacing="1">
                            <TextBlock Text="2/4 — Seleziona utente" FontSize="14" FontWeight="Bold"
                                       Foreground="#7986CB" Margin="0,0,0,4"/>
                            <TextBlock x:Name="LabelStep2Device" Text="" FontSize="11"
                                       Foreground="#757575"/>
                        </StackPanel>

                        <TextBlock x:Name="LabelStep2Loading" Text="Caricamento utenti..."
                                   Foreground="#757575" HorizontalAlignment="Center"/>

                        <ListBox x:Name="UserSelectList" MinHeight="34" MaxHeight="140" IsVisible="False"/>

                        <TextBlock x:Name="LabelStep2Warning" Text="" Foreground="#FFB74D"
                                   TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="12"
                                   IsVisible="False"/>

                        <!-- Bottoni normali -->
                        <Grid x:Name="Step2NormalButtons" ColumnDefinitions="*,6,*"
                              HorizontalAlignment="Stretch">
                            <Button Content="Indietro" Grid.Column="0"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnBackToStep1"/>
                            <Button x:Name="BtnStep2Next" Content="Avanti" Grid.Column="2"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Background="#5C6BC0" Foreground="White"
                                    Click="OnStep2Next" IsEnabled="False"/>
                        </Grid>

                        <!-- Conferma cambio utente -->
                        <StackPanel x:Name="Step2ConfirmPanel" IsVisible="False" Spacing="6">
                            <TextBlock x:Name="LabelSwitchStatus" Text="Cambio utente in corso..."
                                       FontWeight="Bold" HorizontalAlignment="Center" FontSize="13"
                                       Foreground="#FFB74D"/>
                            <TextBlock Text="Il cambio utente ha avuto successo?"
                                       HorizontalAlignment="Center" FontSize="13"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="#B0BEC5"/>

                            <Grid ColumnDefinitions="*,6,*,6,*" HorizontalAlignment="Stretch">
                                <Button Content="SI" Grid.Column="0"
                                        HorizontalAlignment="Stretch" Padding="6,3"
                                        Background="#2E7D32" Foreground="White"
                                        Click="OnSwitchConfirmYes"/>
                                <Button Content="RIPROVA" Grid.Column="2"
                                        HorizontalAlignment="Stretch" Padding="6,3"
                                        Background="#E65100" Foreground="White"
                                        Click="OnSwitchConfirmRetry"/>
                                <Button Content="ESCI" Grid.Column="4"
                                        HorizontalAlignment="Stretch" Padding="6,3"
                                        Background="#C62828" Foreground="White"
                                        Click="OnSwitchConfirmExit"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock x:Name="LabelStep2Error" Text="" HorizontalAlignment="Center"
                                   Foreground="#EF5350" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- STEP 3: Sorgente + opzioni -->
        <ScrollViewer x:Name="Step3" IsVisible="False">
            <StackPanel Margin="12,8" Spacing="8">
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="3/4 — Dispositivo sorgente" FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <TextBlock Text="Da quale dispositivo copiare le foto?"
                                   Foreground="#757575" FontSize="13"/>

                        <ListBox x:Name="SourceDeviceList" MinHeight="34" MaxHeight="120"/>

                        <CheckBox x:Name="ChkDeleteFromSource"
                                  Content="Cancella foto dalla sorgente dopo il backup"/>

                        <Grid ColumnDefinitions="*,6,*" HorizontalAlignment="Stretch">
                            <Button Content="Indietro" Grid.Column="0"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnBackToStep2"/>
                            <Button x:Name="BtnStep3Start" Content="Avvia backup" Grid.Column="2"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Background="#2E7D32" Foreground="White"
                                    Click="OnStep3Start"/>
                        </Grid>

                        <TextBlock x:Name="LabelStep3Error" Text="" HorizontalAlignment="Center"
                                   Foreground="#EF5350" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- STEP 4: Trasferimento + Risultato -->
        <ScrollViewer x:Name="Step4" IsVisible="False">
            <StackPanel Margin="12,8" Spacing="8">
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="4/4 — Trasferimento" FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <!-- Progresso -->
                        <StackPanel x:Name="WizardProgressPanel" Spacing="6">
                            <TextBlock x:Name="LabelWizardStatus" Text="Preparazione..."
                                       HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"
                                       Foreground="#7986CB"/>
                            <ProgressBar x:Name="WizardProgressBar" Minimum="0" Maximum="100" Value="0"/>
                            <TextBlock x:Name="LabelWizardFile" Text="" HorizontalAlignment="Center"
                                       Foreground="#757575" FontSize="11" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="LabelWizardCount" Text="" HorizontalAlignment="Center"
                                       FontSize="13" Foreground="#B0BEC5"/>
                        </StackPanel>

                        <!-- Risultato -->
                        <Border x:Name="WizardResultPanel" IsVisible="False"
                                CornerRadius="6" Padding="5">
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="LabelWizardResultIcon" Text="" FontSize="14"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="LabelWizardResultDetails" Text="" TextWrapping="Wrap"
                                           FontSize="12" Foreground="#B0BEC5"/>
                                <TextBlock x:Name="LabelWizardResultPath" Text="" Foreground="#757575"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Bottoni finali -->
                        <Grid x:Name="WizardEndButtons" IsVisible="False"
                              ColumnDefinitions="*,6,*" HorizontalAlignment="Stretch">
                            <Button x:Name="BtnDeleteTemp" Content="Elimina cartella temp" Grid.Column="0"
                                    HorizontalAlignment="Stretch" Padding="6,3" IsEnabled="False"
                                    Background="#C62828" Foreground="White"
                                    Click="OnDeleteTempClick"/>
                            <Button Content="Home" Grid.Column="2"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnBackToStep0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
