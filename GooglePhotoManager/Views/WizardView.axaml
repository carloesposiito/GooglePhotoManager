<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GooglePhotoManager.Views.WizardView">

    <Grid RowDefinitions="*">

        <!-- STEP 0: Home -->
        <StackPanel x:Name="Step0" Margin="20,16" Spacing="16" VerticalAlignment="Center">
            <TextBlock Text="Backup Foto" FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#7986CB"/>
            <TextBlock Text="Trasferisci le foto dai tuoi dispositivi al dispositivo di backup"
                       TextWrapping="Wrap" HorizontalAlignment="Center" Foreground="#9E9E9E"
                       FontSize="15" TextAlignment="Center" Margin="12,0"/>
            <Button x:Name="BtnStartWizard" Content="AVVIA"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="68" FontSize="22" FontWeight="Bold"
                    Background="#5C6BC0" Foreground="White"
                    Margin="20,12,20,0"
                    Click="OnStartWizardClick"/>
            <TextBlock x:Name="LabelStep0Error" Text="" HorizontalAlignment="Center"
                       Foreground="#EF5350" FontSize="14"/>
        </StackPanel>

        <!-- STEP 1: Backup device -->
        <StackPanel x:Name="Step1" IsVisible="False" Margin="14,8" Spacing="8">
            <Border Background="#1A237E" CornerRadius="8" Padding="10,7">
                <TextBlock Text="1/4 — Dispositivo di backup"
                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                           Foreground="#C5CAE9"/>
            </Border>

            <TextBlock Text="Quale dispositivo ricevera le foto?"
                       Foreground="#9E9E9E" HorizontalAlignment="Center" FontSize="14"/>

            <ListBox x:Name="BackupDeviceList" MinHeight="60" MaxHeight="200"/>

            <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch" Margin="0,4,0,0">
                <Button Content="Indietro" Grid.Column="0" Margin="0,0,4,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Click="OnBackToStep0"/>
                <Button x:Name="BtnStep1Next" Content="Avanti" Grid.Column="1" Margin="4,0,0,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="#5C6BC0" Foreground="White"
                        Click="OnStep1Next"/>
            </Grid>
            <TextBlock x:Name="LabelStep1Error" Text="" HorizontalAlignment="Center"
                       Foreground="#EF5350" FontSize="14"/>
        </StackPanel>

        <!-- STEP 2: Utente -->
        <StackPanel x:Name="Step2" IsVisible="False" Margin="14,8" Spacing="8">
            <Border Background="#1A237E" CornerRadius="8" Padding="10,7">
                <StackPanel Spacing="1">
                    <TextBlock Text="2/4 — Seleziona utente"
                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="#C5CAE9"/>
                    <TextBlock x:Name="LabelStep2Device" Text="" FontSize="13"
                               Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="LabelStep2Loading" Text="Caricamento utenti..."
                       Foreground="#9E9E9E" HorizontalAlignment="Center"/>

            <ListBox x:Name="UserSelectList" MinHeight="60" MaxHeight="180" IsVisible="False"/>

            <TextBlock x:Name="LabelStep2Warning" Text="" Foreground="#FFB74D"
                       TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="14"
                       IsVisible="False"/>

            <!-- Bottoni normali -->
            <Grid x:Name="Step2NormalButtons" ColumnDefinitions="*,*"
                  HorizontalAlignment="Stretch" Margin="0,4,0,0">
                <Button Content="Indietro" Grid.Column="0" Margin="0,0,4,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Click="OnBackToStep1"/>
                <Button x:Name="BtnStep2Next" Content="Avanti" Grid.Column="1" Margin="4,0,0,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="#5C6BC0" Foreground="White"
                        Click="OnStep2Next" IsEnabled="False"/>
            </Grid>

            <!-- Conferma cambio utente -->
            <StackPanel x:Name="Step2ConfirmPanel" IsVisible="False" Spacing="8">
                <Border Background="#37474F" CornerRadius="8" Padding="12,10">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="LabelSwitchStatus" Text="Cambio utente in corso..."
                                   FontWeight="Bold" HorizontalAlignment="Center" FontSize="15"
                                   Foreground="#FFB74D"/>
                        <TextBlock Text="Il cambio utente ha avuto successo?"
                                   HorizontalAlignment="Center" FontSize="15"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="#E0E0E0"/>
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
                    <Button Content="SI" Grid.Column="0"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            MinHeight="54" FontSize="17" FontWeight="Bold" Margin="0,0,3,0"
                            Background="#2E7D32" Foreground="White"
                            Click="OnSwitchConfirmYes"/>
                    <Button Content="RIPROVA" Grid.Column="1"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            MinHeight="54" FontSize="17" FontWeight="Bold" Margin="3,0"
                            Background="#E65100" Foreground="White"
                            Click="OnSwitchConfirmRetry"/>
                    <Button Content="ESCI" Grid.Column="2"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            MinHeight="54" FontSize="17" FontWeight="Bold" Margin="3,0,0,0"
                            Background="#C62828" Foreground="White"
                            Click="OnSwitchConfirmExit"/>
                </Grid>
            </StackPanel>

            <TextBlock x:Name="LabelStep2Error" Text="" HorizontalAlignment="Center"
                       Foreground="#EF5350" FontSize="14"/>
        </StackPanel>

        <!-- STEP 3: Sorgente + opzioni -->
        <StackPanel x:Name="Step3" IsVisible="False" Margin="14,8" Spacing="8">
            <Border Background="#1A237E" CornerRadius="8" Padding="10,7">
                <TextBlock Text="3/4 — Dispositivo sorgente"
                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                           Foreground="#C5CAE9"/>
            </Border>

            <TextBlock Text="Da quale dispositivo copiare le foto?"
                       Foreground="#9E9E9E" HorizontalAlignment="Center" FontSize="14"/>

            <ListBox x:Name="SourceDeviceList" MinHeight="60" MaxHeight="140"/>

            <Border Background="#37474F" CornerRadius="8" Padding="10,6">
                <CheckBox x:Name="ChkDeleteFromSource"
                          Content="Cancella foto dalla sorgente dopo il backup"/>
            </Border>

            <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch" Margin="0,4,0,0">
                <Button Content="Indietro" Grid.Column="0" Margin="0,0,4,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Click="OnBackToStep2"/>
                <Button x:Name="BtnStep3Start" Content="AVVIA BACKUP" Grid.Column="1" Margin="4,0,0,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="#2E7D32" Foreground="White" FontWeight="Bold"
                        Click="OnStep3Start"/>
            </Grid>
            <TextBlock x:Name="LabelStep3Error" Text="" HorizontalAlignment="Center"
                       Foreground="#EF5350" FontSize="14"/>
        </StackPanel>

        <!-- STEP 4: Trasferimento + Risultato -->
        <ScrollViewer x:Name="Step4" IsVisible="False">
            <StackPanel Margin="14,8" Spacing="10">
                <Border Background="#1A237E" CornerRadius="8" Padding="10,7">
                    <TextBlock Text="4/4 — Trasferimento"
                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="#C5CAE9"/>
                </Border>

                <StackPanel x:Name="WizardProgressPanel" Spacing="8">
                    <TextBlock x:Name="LabelWizardStatus" Text="Preparazione..."
                               HorizontalAlignment="Center" FontWeight="Bold" FontSize="16"
                               Foreground="#7986CB"/>
                    <ProgressBar x:Name="WizardProgressBar" Minimum="0" Maximum="100" Value="0"/>
                    <TextBlock x:Name="LabelWizardFile" Text="" HorizontalAlignment="Center"
                               Foreground="#9E9E9E" FontSize="14" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="LabelWizardCount" Text="" HorizontalAlignment="Center"
                               FontSize="15" FontWeight="SemiBold" Foreground="#B0BEC5"/>
                </StackPanel>

                <Border x:Name="WizardResultPanel" IsVisible="False" CornerRadius="10"
                        Padding="14" Margin="0,4,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="LabelWizardResultIcon" Text="" FontSize="32"
                                   HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock x:Name="LabelWizardResultTitle" Text="" FontSize="18"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="LabelWizardResultDetails" Text="" TextWrapping="Wrap"
                                   FontSize="14" Foreground="#B0BEC5"/>
                        <TextBlock x:Name="LabelWizardResultPath" Text="" Foreground="#757575"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid x:Name="WizardEndButtons" IsVisible="False"
                      ColumnDefinitions="*,*" HorizontalAlignment="Stretch" Margin="0,8,0,0">
                    <Button Content="NUOVO BACKUP" Grid.Column="0" Margin="0,0,4,0"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Background="#5C6BC0" Foreground="White" FontWeight="Bold"
                            Click="OnNewWizardClick"/>
                    <Button Content="HOME" Grid.Column="1" Margin="4,0,0,0"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Click="OnBackToStep0"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
