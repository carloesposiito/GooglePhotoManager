<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GooglePhotoManager.Controls"
             x:Class="GooglePhotoManager.Views.CommandsView">

    <Grid RowDefinitions="*">

        <!-- Menu comandi -->
        <ScrollViewer x:Name="MenuPanel">
            <StackPanel Margin="12,8" Spacing="8">

                <!-- === Dispositivo === -->
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Dispositivo" FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <ComboBox x:Name="DeviceSelectCombo" HorizontalAlignment="Stretch"
                                  PlaceholderText="Seleziona dispositivo..."
                                  SelectionChanged="OnDeviceSelectionChanged"/>
                    </StackPanel>
                </Border>

                <!-- === Comandi === -->
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Comandi" FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <Button x:Name="BtnTransferDocs" Content="Trasferisci in Documents"
                                HorizontalAlignment="Stretch" Padding="6,3" IsEnabled="False"
                                Background="#5C6BC0" Foreground="White"
                                Click="OnTransferDocsClick"/>
                        <Button x:Name="BtnBackupFolder" Content="Backup cartella"
                                HorizontalAlignment="Stretch" Padding="6,3" IsEnabled="False"
                                Background="#5C6BC0" Foreground="White"
                                Click="OnBackupFolderClick"/>
                        <Button x:Name="BtnSwitchUser" Content="Cambia utente"
                                HorizontalAlignment="Stretch" Padding="6,3" IsEnabled="False"
                                Background="#5C6BC0" Foreground="White"
                                Click="OnSwitchUserClick"/>
                        <Button x:Name="BtnCreateUser" Content="Crea utente"
                                HorizontalAlignment="Stretch" Padding="6,3" IsEnabled="False"
                                Background="#5C6BC0" Foreground="White"
                                Click="OnCreateUserClick"/>
                        <Button x:Name="BtnReboot" Content="Riavvia"
                                HorizontalAlignment="Stretch" Padding="6,3" IsEnabled="False"
                                Background="#5C6BC0" Foreground="White"
                                Click="OnRebootClick"/>

                        <TextBlock x:Name="LabelMenuError" Text="" HorizontalAlignment="Center"
                                   Foreground="#EF5350" FontSize="11"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Pannello operazione -->
        <ScrollViewer x:Name="OperationPanel" IsVisible="False">
            <StackPanel Margin="12,8" Spacing="8">

                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="LabelOpTitle" Text="" FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <!-- Selezione cartella -->
                        <StackPanel x:Name="FolderSelectPanel" IsVisible="False" Spacing="6">
                            <TextBlock Text="Seleziona cartella:" FontSize="13"
                                       Foreground="#B0BEC5"/>
                            <ListBox x:Name="FolderSelectList" MaxHeight="160"
                                     SelectionChanged="OnFolderSelected"/>
                        </StackPanel>

                        <!-- Lista file -->
                        <StackPanel x:Name="FileListPanel" IsVisible="False" Spacing="6">
                            <TextBlock x:Name="LabelFileListTitle" Text="" FontSize="13"
                                       Foreground="#B0BEC5"/>
                            <ListBox x:Name="FileList" MaxHeight="120"/>
                            <Button x:Name="BtnStartTransfer" Content="Avvia trasferimento"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Background="#2E7D32" Foreground="White"
                                    Click="OnStartTransferClick"/>
                        </StackPanel>

                        <!-- Selezione utente -->
                        <StackPanel x:Name="UserSelectPanel" IsVisible="False" Spacing="6">
                            <TextBlock Text="Seleziona utente:" FontSize="13"
                                       Foreground="#B0BEC5"/>
                            <ListBox x:Name="UserSelectList" MaxHeight="140"
                                     SelectionChanged="OnUserSelected"/>
                            <TextBlock x:Name="LabelUserStatus" Text="" Foreground="#757575"
                                       HorizontalAlignment="Center" FontSize="11"/>
                        </StackPanel>

                        <!-- Conferma riavvio -->
                        <StackPanel x:Name="RebootConfirmPanel" IsVisible="False" Spacing="6">
                            <TextBlock Text="Sei sicuro di voler riavviare il dispositivo?"
                                       HorizontalAlignment="Center" FontSize="14"
                                       Foreground="#FFB74D" TextWrapping="Wrap" TextAlignment="Center"/>
                            <Grid ColumnDefinitions="*,6,*" HorizontalAlignment="Stretch">
                                <Button Content="SI, RIAVVIA" Grid.Column="0"
                                        HorizontalAlignment="Stretch" Padding="6,3"
                                        Background="#C62828" Foreground="White"
                                        Click="OnRebootConfirmYes"/>
                                <Button Content="ANNULLA" Grid.Column="2"
                                        HorizontalAlignment="Stretch" Padding="6,3"
                                        Click="OnBackClick"/>
                            </Grid>
                        </StackPanel>

                        <!-- Progresso -->
                        <StackPanel x:Name="ProgressPanel" IsVisible="False" Spacing="6">
                            <TextBlock x:Name="LabelProgressStatus" Text=""
                                       HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"
                                       Foreground="#7986CB"/>
                            <ProgressBar x:Name="ProgressBarOp" Minimum="0" Maximum="100" Value="0"/>
                            <TextBlock x:Name="LabelProgressFile" Text="" HorizontalAlignment="Center"
                                       Foreground="#757575" FontSize="11" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="LabelProgressCount" Text="" HorizontalAlignment="Center"
                                       FontSize="13" Foreground="#B0BEC5"/>
                        </StackPanel>

                        <!-- Risultato -->
                        <StackPanel x:Name="ResultPanel" IsVisible="False" Spacing="6">
                            <TextBlock x:Name="LabelResultTitle" Text="" FontSize="14"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="LabelResultDetails" Text="" TextWrapping="Wrap"
                                       FontSize="12" Foreground="#B0BEC5"/>
                        </StackPanel>

                        <!-- Bottoni finali (2 colonne se "Apri cartella" visibile, altrimenti 1) -->
                        <Grid x:Name="EndButtonsPanel" IsVisible="False"
                              HorizontalAlignment="Stretch">
                            <Button x:Name="BtnBack" Content="Torna ai comandi"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnBackClick"/>
                        </Grid>
                        <Grid x:Name="EndButtonsWithFolderPanel" IsVisible="False"
                              ColumnDefinitions="*,6,*" HorizontalAlignment="Stretch">
                            <Button Content="Torna ai comandi" Grid.Column="0"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnBackClick"/>
                            <Button x:Name="BtnOpenFolder" Content="Apri cartella" Grid.Column="2"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Background="#5C6BC0" Foreground="White"
                                    Click="OnOpenFolderClick"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Overlay tastiera testo -->
        <Border x:Name="TextKeypadOverlay" IsVisible="False" Background="#CC000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#1E1E1E" CornerRadius="10" Padding="8"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="360" MaxWidth="400" BorderBrush="#5C6BC0" BorderThickness="1">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="TextKeypadTitle" Text="" FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#7986CB"/>
                    <controls:TextKeypad x:Name="TextKbd"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
