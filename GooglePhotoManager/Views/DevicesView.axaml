<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GooglePhotoManager.Controls"
             x:Class="GooglePhotoManager.Views.DevicesView">

    <Grid RowDefinitions="*">
        <ScrollViewer x:Name="MainContent">
            <StackPanel Margin="12,8" Spacing="8">

                <!-- === Dispositivi connessi === -->
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="LabelDevicesHeader" Text="Dispositivi connessi"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <Button x:Name="BtnScan" Content="Scansiona"
                                HorizontalAlignment="Stretch" Padding="6,3"
                                Margin="0,0,0,5" Click="OnScanClick"/>

                        <ListBox x:Name="DeviceList" MinHeight="34" MaxHeight="120"
                                 IsHitTestVisible="False"/>

                        <TextBlock x:Name="LabelStatus" Text="Premi Scansiona per cercare dispositivi"
                                   Foreground="#757575" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- === Connessione wireless === -->
                <Border Background="#1E1E1E" CornerRadius="6" Padding="20,15"
                        BorderBrush="#333333" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Connessione wireless" FontSize="14" FontWeight="Bold"
                                   Foreground="#7986CB" Margin="0,0,0,4"/>

                        <Grid ColumnDefinitions="*,6,*,6,*" HorizontalAlignment="Stretch"
                              Margin="0,0,0,5">
                            <Button x:Name="BtnIpInput" Content="IP: tocca" Grid.Column="0"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnIpInputClick"
                                    Background="#2C2C2C" Foreground="#757575" FontWeight="Normal"/>
                            <Button x:Name="BtnPortInput" Content="Porta: 5555" Grid.Column="2"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnPortInputClick"
                                    Background="#2C2C2C" Foreground="#B0BEC5" FontWeight="Normal"/>
                            <Button x:Name="BtnCodeInput" Content="Codice: tocca" Grid.Column="4"
                                    HorizontalAlignment="Stretch" Padding="6,3"
                                    Click="OnCodeInputClick"
                                    Background="#2C2C2C" Foreground="#757575" FontWeight="Normal"/>
                        </Grid>

                        <Button x:Name="BtnConnect" Content="Connetti" Padding="6,3"
                                HorizontalAlignment="Stretch"
                                Click="OnConnectClick"
                                Background="#5C6BC0" Foreground="White"/>

                        <TextBlock x:Name="LabelWirelessResult" Text="" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" Foreground="#757575" FontSize="11"
                                   Margin="0,0,0,2"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Overlay tastierino -->
        <Border x:Name="KeypadOverlay" IsVisible="False" Background="#CC000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#1E1E1E" CornerRadius="10" Padding="8"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="240" MaxWidth="300" BorderBrush="#5C6BC0" BorderThickness="1">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="KeypadTitle" Text="" FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#7986CB"/>
                    <controls:NumericKeypad x:Name="Keypad"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
