<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GooglePhotoManager.Controls.NumericKeypad">

    <StackPanel Spacing="2">
        <!-- Display -->
        <Border Background="#2C2C2C" CornerRadius="6" Padding="8,5" MinHeight="34"
                BorderBrush="#5C6BC0" BorderThickness="1">
            <TextBlock x:Name="Display" Text="" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#E0E0E0"/>
        </Border>

        <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
            <Button Content="1" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="1"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
            <Button Content="2" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="2"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
            <Button Content="3" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="3"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
        </Grid>
        <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
            <Button Content="4" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="4"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
            <Button Content="5" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="5"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
            <Button Content="6" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="6"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
        </Grid>
        <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
            <Button Content="7" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="7"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
            <Button Content="8" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="8"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
            <Button Content="9" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="9"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
        </Grid>
        <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
            <Button Content="." Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="."
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
            <Button Content="0" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnKeyClick" Tag="0"
                    Background="#2C2C2C" Foreground="#E0E0E0" CornerRadius="6"/>
            <Button Content="&#x232B;" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="40" FontSize="17" Margin="1" Padding="0" Click="OnBackspaceClick"
                    Background="#3E2723" Foreground="#EF9A9A" CornerRadius="6"/>
        </Grid>

        <Grid ColumnDefinitions="*,*" HorizontalAlignment="Stretch" Margin="0,2,0,0">
            <Button x:Name="BtnCancel" Content="Annulla" Grid.Column="0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="44" FontSize="15" Margin="1" Padding="0" Click="OnCancelClick"/>
            <Button x:Name="BtnOk" Content="OK" Grid.Column="1"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    MinHeight="44" FontSize="15" FontWeight="Bold" Margin="1" Padding="0" Click="OnOkClick"
                    Background="#2E7D32" Foreground="White"/>
        </Grid>
    </StackPanel>
</UserControl>
